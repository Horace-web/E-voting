# Configuration de l'API E-Voting Frontend
# Copiez ce fichier vers .env.local pour le développement

# ============================================
# URL DE L'API BACKEND
# ============================================
# Production (Netlify)
# VITE_API_URL=https://evoting-api.rps-benin.com/api

# Développement local
VITE_API_URL=http://localhost:8000/api

# ============================================
# MODE MOCK
# ============================================
# true  = utilise les données simulées (sans backend)
# false = appelle le vrai backend
VITE_USE_MOCK=true

# ============================================
# ENVIRONNEMENT
# ============================================
VITE_APP_ENV=development

# ============================================
# SENTRY (MONITORING FRONT)
# ============================================
# Active/desactive Sentry sur le frontend
VITE_SENTRY_ENABLED=false

# DSN public Sentry (frontend)
VITE_SENTRY_DSN=

# Taux de traces performance (0.0 -> 1.0)
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# NOTES
# ============================================
# - Le fichier .env.production est utilisé lors du build (npm run build)
# - Le fichier .env.local est utilisé en développement (npm run dev)
# - Ne committez JAMAIS de secrets dans .env.example
